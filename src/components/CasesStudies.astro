<style>
  .cases {
    padding: clamp(70px, 8vw, 120px) 0;
  }

  .cases__tag {
    color: var(--color-accent);
    text-align: center;
    margin-bottom: 10px;
  }

  .cases__title {
    text-align: center;
    font-size: clamp(2rem, 4vw, 3.5rem);
    margin-bottom: clamp(40px, 6vw, 70px);
  }

  /* SLIDER */

  .cases__slider {
    overflow: hidden;
    position: relative;
  }

  .cases__controls {
    position: absolute;
    top: 20px;
    right: 20px;
    display: flex;
    gap: 10px;
    z-index: 20;
  }

  /* TRACK */

  .cases__track {
    display: flex;
    gap: 30px;
    transition: transform 0.4s ease;
  }

  /* CARD */

  .case {
    display: grid;
    grid-template-columns: 2fr 1fr;
    background: #111;
    border-radius: 18px;
    overflow: hidden;
    min-width: 100%;
  }

  /* IMAGE */

  .case__image {
    position: relative;
    padding: clamp(30px, 5vw, 60px);
    display: flex;
    align-items: flex-end;
    background-size: cover;
    background-position: center;
  }

  .case__image::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.9), rgba(0, 0, 0, 0.4));
  }

  .case__overlay {
    position: relative;
    z-index: 2;
  }

  .case__overlay h3 {
    margin-bottom: 12px;
  }

  .case__overlay p {
    opacity: 0.8;
  }

  /* STATS */

  .case__stats {
    background: #1f1f1f;
    padding: 30px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 70px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .stat strong {
    color: var(--color-accent);
    line-height: 1;
  }

  .stat span {
    opacity: 0.7;
  }

  /* TABLET */

  @media (max-width: 900px) {
    .case {
      grid-template-columns: 1fr;
    }

    .case__image {
      height: 260px;
      padding: 24px;
    }

    .case__stats {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      align-items: stretch;
    }

    .stat {
      height: 100%;
      min-height: 80px;
      padding: 14px;
      background: rgba(255, 255, 255, 0.04);
      border-radius: 10px;
      border: none;
    }
  }

  /* MOBILE */

  @media (max-width: 600px) {
    .case__stats {
      grid-template-columns: 1fr;
    }

    .stat {
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 0;
      background: none;
      padding: 12px 0;
    }
  }
</style>

<script is:inline>
  const track = document.querySelector(".cases__track");
  const prev = document.querySelector(".prev");
  const next = document.querySelector(".next");

  let index = 0;
  const maxSlides = track.children.length - 1;

  if (track && prev && next) {
    next.addEventListener("click", () => {
      if (index < maxSlides) {
        index++;
        track.style.transform = `translateX(-${index * 100}%)`;
      }
    });

    prev.addEventListener("click", () => {
      if (index > 0) {
        index--;
        track.style.transform = `translateX(-${index * 100}%)`;
      }
    });
  }
</script>
