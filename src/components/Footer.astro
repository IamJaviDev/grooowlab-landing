---
import shopify from "../assets/shopify-partners.png";
import meta from "../assets/meta-partners.png";
import tiktok from "../assets/tiktok-partners.png";
import klaviyo from "../assets/klaviyo-partners.png";
---

<footer class="footer">
  <div class="footer-line"></div>

  <!-- PARTNERS TOP CENTRADO DE VERDAD -->
  <div class="footer-partners-top">
    <p class="footer-partners-title">Partners & herramientas</p>

    <div class="footer-partners">
      <img src={shopify.src} alt="Klaviyo Partner" />
      <img src={meta.src} alt="Klaviyo Partner" />
      <img src={tiktok.src} alt="Klaviyo Partner" />
      <img src={klaviyo.src} alt="Klaviyo Partner" />
    </div>
  </div>

  <div class="footer-container">
    <!-- LEFT -->
    <div class="footer-left">
      <img src="/growlab-logo.png" class="footer-logo" alt="logo" />
    </div>

    <!-- CENTER -->
    <nav class="footer-nav">
      <a href="#servicios">Servicios</a>
      <a href="#resultados">Nuestros resultados</a>
      <a href="#sistema">Nuestro Proceso</a>
      <a href="#contacto">Contacta</a>
    </nav>

    <!-- RIGHT -->
    <div class="footer-right">
      <a href="#contact" class="footer-cta">
        Call Gratuita. Sin trampa, sin cartón.
      </a>

      <div class="footer-legal">
        <a href="mailto:hello@grooowlab.com" class="footer-email">
          hello@grooowlab.com
        </a>
        <a href="/aviso-legal">Aviso legal</a>
        <a href="/politicas-privacidad">Política de privacidad</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: clamp(60px, 7vw, 100px) 20px;
    max-width: 1400px;
    margin: auto;
  }

  .footer-line {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.15),
      transparent
    );
    margin-bottom: clamp(30px, 5vw, 50px);
  }

  /* PARTNERS TOP */

  .footer-partners-top {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-bottom: clamp(40px, 6vw, 60px);
  }

  .footer-partners-title {
    font-size: 0.8rem;
    color: #666;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 18px;
    text-align: center;
  }

  .footer-partners {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: clamp(24px, 4vw, 48px);
    flex-wrap: wrap;
    width: 100%;
    max-width: 900px;
  }

  .footer-partners img {
    height: 54px;
    opacity: 0.5;
    filter: grayscale(1) brightness(1.2);
    transition: 0.3s;
  }

  /* GRID */

  .footer-container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 40px;
  }

  /* LEFT */

  .footer-left {
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .footer-logo {
    width: 120px;
    filter: drop-shadow(0 0 10px var(--color-accent))
      drop-shadow(0 0 20px var(--color-accent));
  }

  /* CENTER */

  .footer-nav {
    display: flex;
    gap: clamp(18px, 3vw, 30px);
    justify-content: center;
    align-items: center;
  }

  .footer-nav a {
    color: #aaa;
    text-decoration: none;
    font-size: 0.9rem;
    transition: 0.2s;
  }

  .footer-nav a:hover {
    color: #fff;
  }

  /* RIGHT */

  .footer-right {
    text-align: right;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 15px;
  }

  .footer-cta {
    display: inline-block;
    padding: 12px 26px;
    border-radius: 8px;
    background: var(--color-accent);
    color: #000;
    font-weight: 600;
    box-shadow: 0 0 25px rgba(224, 255, 63, 0.35);
    font-size: 0.9rem;
  }

  .footer-legal {
    font-size: 0.8rem;
    color: #777;
    display: flex;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 15px;
  }

  .footer-legal a {
    color: #777;
    text-decoration: none;
    transition: 0.2s;
  }

  .footer-legal a:hover {
    color: #fff;
  }

  .footer-email:hover {
    text-shadow: 0 0 6px var(--color-accent);
  }

  /* TABLET */

  @media (max-width: 900px) {
    .footer-container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 40px;
    }

    .footer-left {
      justify-content: center;
    }

    .footer-nav {
      flex-wrap: wrap;
    }

    .footer-right {
      text-align: center;
      align-items: center;
    }

    .footer-legal {
      justify-content: center;
    }
  }

  /* MOBILE */

  @media (max-width: 600px) {
    .footer-nav {
      flex-direction: column;
      gap: 12px;
    }

    .footer-partners img {
      height: 30px;
      gap: 6px;
      flex-wrap: nowrap;
    }
  }
</style>
