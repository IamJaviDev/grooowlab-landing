<header class="navbar">
  <div class="container navbar__inner">
    <div class="navbar__logo">
      <img src="/growlab-logo.png" alt="GrooowLab logo" />
    </div>

    <nav class="navbar__menu">
      <a href="#servicios">Servicios</a>
      <a href="#sistema">Sistema</a>
      <a href="#casos">Casos</a>
      <a href="#faq">FAQ</a>
    </nav>

    <a href="#contact" class="navbar__cta">Reserva una auditoría</a>

    <button class="navbar__toggle" id="menuToggle" aria-label="Menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobileMenu">
    <a href="#casos">Casos de éxito</a>
    <a href="#servicios">Nuestros Servicios</a>
    <a href="#sistema">Nuestro Proceso</a>
    <a href="#faq">Sobre Nosotros</a>

    <a href="#contact" class="mobile-cta">Agenda tu discovery call gratuita</a>
  </div>
</header>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 200;
    padding: 18px 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(10px);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .navbar__logo img {
    height: clamp(32px, 3vw, 40px);
    filter: drop-shadow(0 0 15px var(--color-accent));
  }

  .navbar__menu {
    display: flex;
    gap: 28px;
  }

  .navbar__menu a {
    opacity: 0.8;
    transition: 0.2s;
  }

  .navbar__cta {
    background: var(--color-accent);
    color: #000;
    padding: 10px 16px;
    border-radius: 8px;
    font-weight: 600;
    box-shadow: 0 0 25px rgba(224, 255, 63, 0.35);
  }

  /* HAMBURGER */

  .navbar__toggle {
    display: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #e0ff3f55;
    border: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 6px;
    cursor: pointer;
  }

  .navbar__toggle.active span:nth-child(1) {
    transform: rotate(45deg) translateY(6px);
  }

  .navbar__toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .navbar__toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translateY(-6px);
  }

  .navbar__toggle span {
    width: 20px;
    height: 2px;
    background: var(--color-accent);
  }

  /* MOBILE MENU */

  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;

    background: #000;

    z-index: 9999;

    padding: 120px 40px 60px;

    display: flex;
    flex-direction: column;
    gap: 28px;

    font-size: 1.6rem;

    transform: translateY(-100%);
    transition: transform 0.4s ease;

    overflow-y: auto;
  }

  .mobile-menu.active {
    transform: translateY(0);
  }

  .mobile-cta {
    margin-top: 40px;
    background: var(--color-accent);
    color: #000;
    padding: 18px;
    font-size: clamp(0.95rem, 1.2vw, 1.1rem);
    border-radius: 8px;
    text-align: center;
    font-weight: 600;
  }

  /* RESPONSIVE */

  @media (max-width: 900px) {
    .navbar__menu {
      display: none;
    }

    .navbar__cta {
      display: none;
    }

    .navbar__toggle {
      display: flex;
    }
  }

  @media (min-width: 901px) {
    .mobile-menu {
      display: none;
    }
  }
</style>

<script is:inline>
  const toggle = document.getElementById("menuToggle");
  const menu = document.getElementById("mobileMenu");
  const links = document.querySelectorAll("#mobileMenu a");

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      menu.classList.toggle("active");

      if (menu.classList.contains("active")) {
        document.body.style.overflow = "hidden";
      } else {
        document.body.style.overflow = "";
      }
    });
  }

  /* cerrar menú al hacer click en un enlace */

  links.forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.remove("active");
      document.body.style.overflow = "";
    });
  });
</script>
