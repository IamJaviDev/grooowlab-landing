    text-align: center;
  }

  .contact__tag {
    color: var(--color-accent);
    margin-bottom: 8px;
    font-size: clamp(1rem, 1.2vw, 1.2rem);
    letter-spacing: 0.05em;
  }

  .contact__title {
    margin-top: 0;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 400;
  }

  .contact__subtitle {
    max-width: 600px;
    font-size: clamp(1.1rem, 1.3vw, 1.3rem);
    margin: 0px auto 50px auto;
    opacity: 0.8;
    line-height: 1.6;
  }

  .contact__form {
    max-width: 900px;
    margin: auto;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .form__group input,
  .form__group textarea {
    width: 100%;
    padding: 16px 18px;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: linear-gradient(90deg, #1a1a1a, #2a2a2a);
    color: white;
    font-size: 0.95rem;
  }

  .form__group textarea {
    resize: none;
  }

  .form__group input:focus,
  .form__group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .btn {
    width: 100%;
    max-width: 400px;
    background: var(--color-accent);
    color: #000;
    padding: 14px 26px;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    margin: 20px auto 0 auto; /* centra el botón */
  }

  .btn:hover {
    transform: translateY(-2px);
    transition: 0.25s;
  }

  .form-success {
    display: none;
    margin-top: 20px;
    color: var(--color-accent);
    font-weight: 500;
  }

  @media (max-width: 600px) {
    .contact__form {
      gap: 14px;
    }
  }
</style>
