<section id="contact" class="contact">
  <div class="container">
    <p class="contact__tag">Hablemos</p>

    <h2 class="contact__title">Cuéntanos sobre tu proyecto</h2>

    <p class="contact__subtitle">
      Si tu negocio está listo para escalar, estaremos encantados de escucharte.
      Responderemos en menos de 24 horas.
    </p>

    <form
      class="contact__form"
      action="https://formspree.io/f/mlgplvge"
      method="POST"
    >
      <div class="form__group">
        <input type="text" name="name" placeholder="Nombre" required />
      </div>

      <div class="form__group">
        <input
          type="email"
          name="email"
          placeholder="Correo electrónico"
          required
        />
      </div>

      <div class="form__group">
        <input type="text" name="website" placeholder="Web o negocio" />
      </div>

      <div class="form__group">
        <textarea
          name="message"
          rows="4"
          placeholder="Cuéntanos brevemente qué necesitas"></textarea>
      </div>

      <!-- asunto del email -->

      <input type="hidden" name="_subject" value="Nuevo lead Grooowlab" />

      <!-- redirección después del envío -->

      <input type="hidden" name="_next" value="/gracias" />

      <!-- anti spam -->

      <input type="text" name="_gotcha" style="display:none" />

      <button type="submit" class="btn"> Solicitar contacto </button>
    </form>
  </div>
</section>

<style>
  .contact {
    padding: clamp(70px, 9vw, 120px) 0;
    text-align: center;
  }

  .contact__tag {
    color: var(--color-accent);
    margin-bottom: 8px;
    font-size: clamp(1rem, 1.2vw, 1.2rem);
    letter-spacing: 0.05em;
  }

  .contact__title {
    margin-top: 0;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 400;
  }

  .contact__subtitle {
    max-width: 600px;
    margin: 20px auto 50px auto;
    opacity: 0.8;
    line-height: 1.6;
  }

  .contact__form {
    max-width: 600px;
    margin: auto;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .form__group input,
  .form__group textarea {
    width: 100%;
    padding: 16px 18px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: linear-gradient(90deg, #1a1a1a, #2a2a2a);
    color: white;
    font-size: 0.95rem;
  }

  .form__group textarea {
    resize: none;
  }

  .form__group input:focus,
  .form__group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .btn {
    background: var(--color-accent);
    color: #000;
    padding: 14px 26px;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    margin-top: 10px;
  }

  .btn:hover {
    transform: translateY(-2px);
    transition: 0.25s;
  }

  @media (max-width: 600px) {
    .contact__form {
      gap: 14px;
    }
  }
</style>
